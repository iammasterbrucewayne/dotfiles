#!/usr/bin/env bash
set -euo pipefail

field="${1:-full}"
cached_only=0
case "$field" in
  cached_subject|cached_body|cached_full)
    cached_only=1
    field="${field#cached_}"
    ;;
esac
primary_model="${LAZYGIT_AI_COMMIT_MODEL:-opencode/minimax-m2.5-free}"
fallback_model="${LAZYGIT_AI_COMMIT_FALLBACK_MODEL:-opencode/gpt-5-nano}"
variant="${LAZYGIT_AI_COMMIT_VARIANT:-minimal}"
strict_primary="${LAZYGIT_AI_COMMIT_STRICT_PRIMARY:-0}"

if [ "$field" = "prewarm" ]; then
  prewarm=1
  field="full"
else
  prewarm=0
fi

if [ "$field" = "commit" ]; then
  commit_mode=1
  field="full"
else
  commit_mode=0
fi

if git diff --cached --quiet; then
  if [ "$prewarm" -eq 1 ]; then
    echo "No staged changes. Stage files first."
    exit 1
  fi
  exit 0
fi

if ! command -v opencode >/dev/null 2>&1; then
  if [ "$prewarm" -eq 1 ]; then
    echo "opencode CLI not found in PATH"
    exit 1
  fi
  exit 0
fi

if ! command -v jq >/dev/null 2>&1; then
  if [ "$prewarm" -eq 1 ]; then
    echo "jq is required for parsing opencode output"
    exit 1
  fi
  exit 0
fi

staged_diff="$(git diff --cached --no-color)"
staged_hash="$(printf "%s\n%s\n%s" "$staged_diff" "$primary_model" "$variant" | shasum -a 256 | cut -d' ' -f1)"

hash_file=".git/.lazygit_ai_commit_hash"
msg_file=".git/.lazygit_ai_commit_msg"
model_file=".git/.lazygit_ai_commit_model"

cached_hash=""
if [ -f "$hash_file" ]; then
  cached_hash="$(cat "$hash_file")"
fi

cache_fresh=0
if [ -f "$msg_file" ] && [ "$cached_hash" = "$staged_hash" ]; then
  cache_fresh=1
fi

generate=0
if [ "$cache_fresh" -ne 1 ]; then
  generate=1
fi
if [ "$prewarm" -eq 1 ]; then
  generate=1
fi
if [ "$cached_only" -eq 1 ]; then
  generate=0
fi

if [ "$cached_only" -eq 1 ] && [ "$cache_fresh" -ne 1 ]; then
  case "$field" in
    subject)
      printf "%s" "Run A to generate AI draft"
      ;;
    body|full)
      printf "%s" ""
      ;;
  esac
  exit 0
fi

used_model=""
if [ "$generate" -eq 1 ]; then
  prompt=$(cat <<'EOF'
Write a Conventional Commit message from this staged diff.

Requirements:
- First line: type(scope): subject
- Allowed types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
- Subject must be imperative and <= 72 characters
- Add one short description paragraph only if useful
- Add BREAKING CHANGE footer only if needed
- Output only the commit message text. No markdown fences or commentary
EOF
)

  run_with_model() {
    local model="$1"
    local out
    local args
    args=(run --format json --model "$model")
    if [ -n "$variant" ]; then
      args+=(--variant "$variant")
    fi
    if ! out="$(opencode "${args[@]}" "$prompt

Staged diff:
$staged_diff" 2>/dev/null)"; then
      return 1
    fi
    commit_msg="$(printf "%s\n" "$out" | jq -rs 'map(select(.type == "text") | .part.text) | last // empty')"
    commit_msg="${commit_msg//$'\r'/}"
    if [ -z "$commit_msg" ]; then
      return 1
    fi
    used_model="$model"
    return 0
  }

  commit_msg=""
  if ! run_with_model "$primary_model"; then
    if [ "$strict_primary" = "1" ] || [ -z "$fallback_model" ]; then
      if [ "$prewarm" -eq 1 ] || [ "$commit_mode" -eq 1 ]; then
        echo "Failed to generate AI commit draft with $primary_model"
        exit 1
      fi
      exit 0
    fi
    if ! run_with_model "$fallback_model"; then
      if [ "$prewarm" -eq 1 ] || [ "$commit_mode" -eq 1 ]; then
        echo "Failed to generate AI commit draft with both $primary_model and $fallback_model"
        exit 1
      fi
      exit 0
    fi
  fi

  printf "%s\n" "$staged_hash" > "$hash_file"
  printf "%s\n" "$commit_msg" > "$msg_file"
  printf "%s\n" "$used_model" > "$model_file"
fi

if [ ! -f "$msg_file" ]; then
  if [ "$prewarm" -eq 1 ] || [ "$commit_mode" -eq 1 ]; then
    echo "No AI draft available"
    exit 1
  fi
  exit 0
fi

commit_msg="$(cat "$msg_file")"

if [ "$commit_mode" -eq 1 ]; then
  printf "%s\n" "$commit_msg" > .git/COMMIT_EDITMSG
  git commit -F .git/COMMIT_EDITMSG
  exit 0
fi

subject="${commit_msg%%$'\n'*}"

body="$(printf "%s" "$commit_msg" | python3 -c 'import sys
text = sys.stdin.read()
lines = text.splitlines()
rest = lines[1:] if len(lines) > 1 else []
while rest and not rest[0].strip():
    rest = rest[1:]
parts = [line.strip() for line in rest if line.strip()]
print(" ".join(parts), end="")')"

if [ "$prewarm" -eq 1 ]; then
  if [ -f "$model_file" ]; then
    used_model="$(cat "$model_file")"
  fi
  echo "AI draft ready (${used_model:-unknown model})"
  echo
  printf "%s\n" "$commit_msg"
  exit 0
fi

case "$field" in
  subject)
    printf "%s" "$subject"
    ;;
  body)
    printf "%s" "$body"
    ;;
  full)
    printf "%s" "$commit_msg"
    ;;
  *)
    printf "%s" "$subject"
    ;;
esac
